{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn app_supabase:app --bind 0.0.0.0:$PORT --timeout 600 --workers 1 --worker-class sync --worker-connections 1000 --max-requests 1000 --max-requests-jitter 50 --limit-request-line 0 --limit-request-field_size 0",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
